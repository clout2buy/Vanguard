{
  "name": "vanguard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A clean-room, verification-first coding agent kernel.",
  "engines": {
    "node": ">=20.19 <25"
  },
  "bin": {
    "vanguard": "./dist/src/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "docs/ACCEPTANCE.md",
    "docs/ARCHITECTURE.md",
    "docs/ARES_INTEGRATION.md",
    "docs/ARES_ROUTE_CLAIM_STORE.md",
    "docs/CERTIFICATION.md",
    "docs/CONTEXT_ARCHITECTURE.md",
    "docs/DELEGATION.md",
    "docs/ENGINE_PROTOCOL.md",
    "docs/GATE_ZERO.md",
    "docs/INDEPENDENCE.md",
    "docs/LIVE_RESULTS.md",
    "docs/MASTER_REPORT.md",
    "docs/PORTABILITY.md",
    "docs/PROVIDERS.md",
    "docs/EXTENSIONS.md",
    "docs/TESTING.md",
    "docs/THREAT_MODEL.md",
    "examples",
    "gauntlet/README.md",
    "scripts/credential.ps1",
    "scripts/export-credential.ps1",
    "scripts/set-project-secret.ps1",
    "scripts/vanguard",
    "scripts/vanguard.ps1",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node scripts/run-tests.mjs",
    "test:providers": "npm run build && node --test dist/test/providerConformance.test.js",
    "test:portability": "npm run build && node --test dist/test/portability.test.js",
    "test:pack": "node scripts/package-smoke.mjs",
    "prepack": "npm run build",
    "vanguard": "npm run build && node dist/src/cli.js",
    "certify": "npm run build && node dist/src/evaluation/certificationCli.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
}
